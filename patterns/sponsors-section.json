style:normal;font-weight:700;letter-spacing:0.96px\">Όλοι οι χορηγοί</a></div>\n<!-- /wp:button --></div>\n<!-- /wp:buttons --></div>\n<!-- /wp:group -->\n\n<!-- wp:wordcamp/sponsors {\"mode\":\"all\",\"show_name\":false,\"show_logo\":true,\"content\":\"none\",\"sponsor_logo_height\":100} /--></section>\n<!-- /wp:group -->",
