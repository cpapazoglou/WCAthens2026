ination\":\"none\"} -->\n<figure class=\"wp-block-image is-resized\"><img alt=\"\" style=\"aspect-ratio:4/3;object-fit:contain;width:150px\" /></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"width\":\"150px\",\"aspectRatio\":\"4/3\",\"scale\":\"contain\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image is-resized\"><img alt=\"\" style=\"aspect-ratio:4/3;object-fit:contain;width:150px\" /></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"width\":\"150px\",\"aspectRatio\":\"4/3\",\"scale\":\"contain\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image is-resized\"><img alt=\"\" style=\"aspect-ratio:4/3;object-fit:contain;width:150px\" /></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"width\":\"150px\",\"aspectRatio\":\"4/3\",\"scale\":\"contain\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image is-resized\"><img alt=\"\" style=\"aspect-ratio:4/3;object-fit:contain;width:150px\" /></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"width\":\"150px\",\"aspectRatio\":\"4/3\",\"scale\":\"contain\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image is-resized\"><img alt=\"\" style=\"aspect-ratio:4/3;object-fit:contain;width:150px\" /></figure>\n<!-- /wp:image --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->",
